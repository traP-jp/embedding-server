# server
API_PORT=8080
APP_ENV=production
JOB_DATA_DIR=/data/jobs

# db
POSTGRES_VERSION=18.3
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=embedding
POSTGRES_SSLMODE=disable

# worker
ATTN_IMPLEMENTATION=sdpa
EMBED_BATCH_SIZE=2
MODEL_NAME=Qwen/Qwen3-VL-Embedding-8B
API_HOST=api
POLL_INTERVAL_SECONDS=5
QWEN_EMBEDDING_SCRIPT=/app/scripts/qwen3_vl_embedding.py
TORCH_DTYPE=float16
MODEL_MAX_PIXELS=
EMBEDDING_WORKER_FAKE=false
FAKE_EMBEDDING_DIM=1024
OCR_ENABLED=true
OCR_DEVICE=cuda
OCR_SCALE=2
OCR_REC_THRESHOLD=0.2
OCR_DET_THRESHOLD=0.2
OCR_MAX_CHARS=256
OCR_VISUALIZE=false
