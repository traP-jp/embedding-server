# server
API_PORT=8080
APP_ENV=production
JOB_DATA_DIR=/data/jobs

# db
POSTGRES_VERSION=18.3
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=embedding
POSTGRES_SSLMODE=disable

# worker
ATTN_IMPLEMENTATION=sdpa
API_HOST=api
POLL_INTERVAL_SECONDS=5
TORCH_DTYPE=float16
EMBEDDING_WORKER_FAKE=false # 埋め込みを偽のものにするかどうか（trueの場合、ランダムなベクトルを返す）
FAKE_EMBEDDING_DIM=1024 # 埋め込みの次元数（偽の埋め込みを使用する場合）
OCR_ENABLED=true
OCR_DEVICE=cuda
OCR_SCALE=2
OCR_REC_THRESHOLD=0.2
OCR_DET_THRESHOLD=0.2
OCR_MAX_CHARS=256
OCR_VISUALIZE=false
